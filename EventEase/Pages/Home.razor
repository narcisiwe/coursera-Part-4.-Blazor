@page "/"
@rendermode InteractiveServer
@inject EventService EventService
@inject AttendanceService AttendanceService

<PageTitle>Home - EventEase</PageTitle>

<div class="page-intro">
    <div>
        <span class="page-kicker">Project Dashboard</span>
        <h1 class="page-title">EventEase demo built with Blazor</h1>
        <p class="page-subtitle">This project combines all requested rubric items into one clean demo: editable event cards, routing, validation, debugging improvements, session state, and attendance tracking.</p>
    </div>
    <div class="page-chip">Ready for GitHub submission</div>
</div>

<section class="hero-panel">
    <div class="hero-panel-row">
        <div>
            <h2 class="panel-title">What the reviewer can test</h2>
            <p class="panel-subtitle">Use the sidebar to move through each requirement. The Events page now also supports adding new cards, not only editing or deleting them.</p>
        </div>
        <a class="btn btn-primary" href="events">Open Events Page</a>
    </div>

    <div class="hero-stats">
        <div class="stat-card">
            <strong>@EventService.Events.Count</strong>
            <span>Editable event cards</span>
        </div>
        <div class="stat-card">
            <strong>@AttendanceService.Attendees.Count</strong>
            <span>Current attendees</span>
        </div>
        <div class="stat-card">
            <strong>6</strong>
            <span>Interactive pages</span>
        </div>
        <div class="stat-card">
            <strong>Full</strong>
            <span>Rubric coverage</span>
        </div>
    </div>
</section>

<div class="feature-grid mt-4">
    <div class="feature-card">
        <h3>Foundational Event Card</h3>
        <p>Event title, location, date, description, and seats can be edited live with two-way binding.</p>
    </div>
    <div class="feature-card">
        <h3>Routing</h3>
        <p>Dedicated pages are available for events, registration, attendance, session state, and the Copilot summary.</p>
    </div>
    <div class="feature-card">
        <h3>Validation</h3>
        <p>The registration flow uses <span class="code-chip">EditForm</span>, validation attributes, and user feedback messages.</p>
    </div>
    <div class="feature-card">
        <h3>State Management</h3>
        <p>A scoped session service updates the header badge and related pages without a full reload.</p>
    </div>
</div>
