<div class="event-card">
    <div class="event-card-header">
        <div>
            <div class="card-kicker">Editable event card</div>
            <h3>@Event.Title</h3>
            <div class="event-meta">
                <span class="meta-pill">@Event.Location</span>
                <span class="meta-pill">@Event.Date.ToString("dddd")</span>
                <span class="meta-pill">@Event.AvailableSeats seats</span>
            </div>
        </div>
        <span class="date-pill">@Event.Date.ToString("dd MMM yyyy")</span>
    </div>

    <div class="card-form-grid">
        <div>
            <label class="form-label">Event title</label>
            <InputText class="form-control" @bind-Value="Event.Title" />
        </div>

        <div class="input-row input-row-3">
            <div>
                <label class="form-label">Location</label>
                <InputText class="form-control" @bind-Value="Event.Location" />
            </div>

            <div>
                <label class="form-label">Date</label>
                <InputDate class="form-control" @bind-Value="Event.Date" />
            </div>

            <div>
                <label class="form-label">Seats</label>
                <InputNumber class="form-control" @bind-Value="Event.AvailableSeats" />
            </div>
        </div>

        <div>
            <label class="form-label">Description</label>
            <InputTextArea class="form-control text-area" @bind-Value="Event.Description" />
        </div>
    </div>

    <div class="event-footer">
        <div>
            <div class="location-inline">Live two-way binding</div>
            <small class="muted">Changes made inside this card are reflected immediately in the shared component state.</small>
        </div>

        <button class="btn btn-sm btn-outline-danger" @onclick="Delete">Delete</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public EventModel Event { get; set; } = default!;
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    private async Task Delete()
    {
        if (OnDelete.HasDelegate)
        {
            await OnDelete.InvokeAsync(Event.Id);
        }
    }
}
